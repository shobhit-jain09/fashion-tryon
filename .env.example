# Backend
API_PORT=8010
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/fashion_tryon
AI_PROVIDER=mock
AI_PROVIDER_API_KEY=replace_me
REPLICATE_MODEL_VERSION=replace_with_replicate_model_version
REPLICATE_WEBHOOK_URL=

# Replicate model input field names (must match your model’s schema)
REPLICATE_INPUT_PERSON_KEY=image
REPLICATE_INPUT_GARMENT_KEY=garment
REPLICATE_INPUT_PROMPT_KEY=prompt

# Catalog: optional override path; default is services/api/app/data/catalog.json
CATALOG_JSON_PATH=

# Flipkart Affiliate (India) — optional live product search
# https://affiliate.flipkart.com/api-docs/
FLIPKART_AFFILIATE_ID=
FLIPKART_AFFILIATE_TOKEN=
FLIPKART_SEARCH_URL=https://affiliate-api.flipkart.net/affiliate/1.0/search.json

STORAGE_BUCKET_URL=https://cdn.example.com/tryon

# Mobile (Expo public vars)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8010
